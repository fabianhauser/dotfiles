[user]
	name = Fabian Hauser
	email = fabian@fh2.ch
	signingkey = 8A52A140BEBF7D2C
[core]
        packedGitWindowSize = 16m
        packedGitLimit = 64m
[pack]
        windowMemory = 64m
        packSizeLimit = 64m
        thread = 1
        deltaCacheSize = 1m
[color]
	branch = auto
	diff = auto
	status = auto
[push]
	default = simple
[pull]
	rebase = true
[branch]
	autosetuprebase = always
[commit]
	gpgsign = true
[gpg]
	program = /opt/fabian/gitgpg2
[tag]
	gpgsign = true

[alias]
	s = status --short --branch
	a = add --patch
	c = commit --message
	l = log --color --graph --pretty=format:'%Cred%h%Creset - %C(bold)%s%Creset%C(yellow)%d%Creset %C(green)%an%Creset %C(cyan)%cr%Creset' --abbrev-commit
	d = diff
