{
  "assistant": {
    "default_model": {
      "model": "gpt-4o-mini",
      "provider": "openai"
    },
    "version": "2"
  },
  "languages": {
    "Markdown": {
      "remove_trailing_whitespace_on_save": false
    },
    "Markdown-Inline": {
      "remove_trailing_whitespace_on_save": false
    },
    "Nix": {
      "language_servers": [
        "nixd",
        "!nil"
      ]
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": false
}
